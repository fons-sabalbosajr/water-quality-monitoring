# scripts/.gitignore
# ──────────────────────────────────────────────────────────────────────────────
# Local maintenance scripts — dependencies and generated output are not committed.

# Dependencies installed by npm (pdfkit etc.)
node_modules/

# Lock file (generated by npm install, not needed in the repo for one-off scripts)
package-lock.json

# Generated outputs — regenerate by running the script
*.pdf
