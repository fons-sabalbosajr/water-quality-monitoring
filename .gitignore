# Root-level .gitignore
# ────────────────────────────────────────────────────────────────────────────
# This file covers the full monorepo.  Each sub-package (.front-end, server,
# scripts) has its own .gitignore for package-local rules.

# ── Build artefacts ──────────────────────────────────────────────────────────
dist/
build/
dist-ssr/
.output/

# ── Environment / secrets ─────────────────────────────────────────────────────
# Never commit real .env files.  Use .env.example as a safe template.
.env
.env.*
!.env.example

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS metadata ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
.Spotlight-V100
.Trashes

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Runtime ──────────────────────────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock

# ── Test / coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Generated / binary output in docs ────────────────────────────────────────
# The PDF is generated by scripts/generateDocsPdf.mjs and should not be committed.
docs/*.pdf

# ── Misc ─────────────────────────────────────────────────────────────────────
*.local
*.tmp
*.bak
