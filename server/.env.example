# server/.env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file.

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>
MONGO_DB_NAME=db-water_quality_monitoring

# JWT secret — use a long, random string in production
JWT_SECRET=change_this_to_a_strong_random_secret

# Express server binding
PORT=5000
# Leave blank to bind all interfaces, or set a specific IP for LAN access
# HOST=192.168.1.100

# Gmail SMTP — use an App Password, NOT your normal login password
# https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# URL the password-reset e-mail links back to (the React app origin)
CLIENT_URL=http://localhost:5173

# Google Gemini AI (optional — for AI forecast features)
GEMINI_API_KEY=your_gemini_api_key_here

# MapTiler API key (optional — for 3D map imagery)
MAPTILER_API_KEY=your_maptiler_api_key_here

# Cesium Ion access token (optional — for 3D globe terrain)
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here
