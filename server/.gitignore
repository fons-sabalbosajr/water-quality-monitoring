# server/.gitignore
# ────────────────────────────────────────────────────────────────────────────

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── Runtime data ─────────────────────────────────────────────────────────────
pids/
*.pid
*.seed

# ── Build output ─────────────────────────────────────────────────────────────
dist/
build/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/

