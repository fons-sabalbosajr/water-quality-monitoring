# front-end/.env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file.

# Leave empty to bind all interfaces (0.0.0.0).
# Set only if you need to pin a specific LAN IP (stale IPs cause EADDRNOTAVAIL).
# VITE_HOST=192.168.1.100

# URL of the Express API server
VITE_API_TARGET=http://localhost:5000

# Cesium Ion access token (https://cesium.com/ion/tokens)
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here
